# Ngrok 认证令牌
# 从 https://dashboard.ngrok.com/get-started/your-authtoken 获取
NGROK_AUTHTOKEN=your_ngrok_token_here

# Ollama 模型配置（逗号分隔）
OLLAMA_MODELS=qwen3:4b,nomic-embed-text:latest

# Ollama 拉取模型代理（可选，用于加速国内下载）
# 格式: http://host.docker.internal:7890  （7890换成你的代理端口）
# 留空则不使用代理
OLLAMA_HTTPS_PROXY=

# ChatChat 配置
CHATCHAT_DATA_PATH=./data
